{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,

    "ignoreDeprecations": "6.0",
  },
  "include": ["src", "prisma.config.ts"]
}
